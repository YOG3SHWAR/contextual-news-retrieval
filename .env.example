# Copy to .env and fill in. The real .env is gitignored (this repo is public).

# Anthropic Claude API key. If unset, the system runs in heuristic mode
# (no LLM calls) and every response is flagged degraded=true for LLM features.
ANTHROPIC_API_KEY=

# Toggle LLM integration entirely (true = use Claude, false = always heuristic).
NEWS_LLM_ENABLED=true

# --- Database (defaults match docker-compose.yml) ---
DB_URL=jdbc:postgresql://localhost:5432/news
DB_USERNAME=news
DB_PASSWORD=news

# --- Redis (optional; system degrades gracefully if down) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Server ---
SERVER_PORT=8080
